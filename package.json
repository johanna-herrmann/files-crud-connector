{
  "name": "files-crud-connector",
  "version": "0.1.0",
  "description": "Connector/Client for REST file storage files-crud, written in Typescript.",
  "contributors": [
    {
      "name": "johanna-herrmann",
      "email": "johanna.herrmann@mailbox.org"
    }
  ],
  "private": false,
  "main": "built/lib/index.js",
  "types": "built/lib/index.d.ts",
  "author": "Johanna Herrmann",
  "scripts": {
    "inst": "npm install",
    "audit": "better-npm-audit audit",
    "lint": "eslint **/*.ts",
    "test": "tsc --noEmit --sourceMap && jest --runInBand --verbose --detectOpenHandles --forceExit",
    "qa": "npm run lint && npm run test",
    "build": "rimraf ./built && tsc && tsc-alias"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johanna-herrmann/files-crud-connector.git"
  },
  "keywords": [
    "files-crud",
    "connector",
    "client",
    "crud",
    "file",
    "storage"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/eslintrc": "3.1.0",
    "@eslint/js": "9.29.0",
    "@types/jest": "29.5.13",
    "@types/node": "22.7.7",
    "@typescript-eslint/eslint-plugin": "8.10.0",
    "@typescript-eslint/parser": "8.10.0",
    "better-npm-audit": "^3.11.0",
    "esbuild-jest": "0.5.0",
    "eslint": "9.13.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.2.1",
    "jest": "29.7.0",
    "prettier": "3.3.3",
    "rimraf": "^6.0.1",
    "ts-jest": "29.2.5",
    "ts-node": "10.9.2",
    "ts-transformer-keys": "^0.4.4",
    "tsc-alias": "1.8.10",
    "typescript": "5.6.3"
  },
  "dependencies": {}
}
